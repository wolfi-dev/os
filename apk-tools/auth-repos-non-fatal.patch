diff --git a/src/print.c b/src/print.c
index 7b7f37a..bfccfeb 100644
--- a/src/print.c
+++ b/src/print.c
@@ -7,9 +7,12 @@
  * SPDX-License-Identifier: GPL-2.0-only
  */
 
+#include <ctype.h>
+#include <fnmatch.h>
 #include <stdio.h>
 #include <stdarg.h>
 #include <stdlib.h>
+#include <string.h>
 #include <unistd.h>
 #include <errno.h>
 #include <sys/ioctl.h>
@@ -186,6 +189,66 @@ void apk_url_parse(struct apk_url_print *urlp, const char *url)
 	};
 }
 
+/*
+ * Match a repository URL against a comma- or space-separated list of
+ * shell-style glob patterns (fnmatch(3): '*', '?', '[...]').
+ */
+int apk_url_host_matches(const char *url, const char *list)
+{
+	const char *authority, *host, *path, *p, *q;
+	char target[PATH_MAX], pattern[PATH_MAX];
+	size_t host_len, path_len, len;
+
+	if (list == NULL || *list == '\0') return 0;
+
+	authority = strstr(url, "://");
+	if (authority == NULL) return 0;
+	authority += 3;
+
+	/* skip optional userinfo (user:password@) */
+	host = authority;
+	for (p = authority; *p && *p != '/'; p++) {
+		if (*p == '@') {
+			host = p + 1;
+			break;
+		}
+	}
+
+	/* host ends at the port or path separator */
+	for (q = host; *q && *q != ':' && *q != '/'; q++)
+		;
+	host_len = q - host;
+	if (host_len == 0) return 0;
+
+	/* skip an optional :port, keep the path from the first '/' */
+	for (path = q; *path && *path != '/'; path++)
+		;
+	path_len = strlen(path);
+
+	/* assemble "host/path" (no scheme, userinfo or port) */
+	if (host_len + path_len >= sizeof target) return 0;
+	memcpy(target, host, host_len);
+	memcpy(target + host_len, path, path_len);
+	target[host_len + path_len] = '\0';
+
+	/* match against each comma/space separated glob pattern */
+	for (p = list; *p; p = q) {
+		while (*p == ',' || isspace((unsigned char)*p))
+			p++;
+		for (q = p; *q && *q != ',' && !isspace((unsigned char)*q); q++)
+			;
+		len = q - p;
+		if (len == 0 || len >= sizeof pattern)
+			continue;
+		memcpy(pattern, p, len);
+		pattern[len] = '\0';
+		if (fnmatch(pattern, target, FNM_CASEFOLD) == 0)
+			return 1;
+	}
+
+	return 0;
+}
