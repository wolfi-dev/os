diff --git a/test/command-parsing.sh b/test/command-parsing.sh
index b68c4ad..2eb7b36 100755
--- a/test/command-parsing.sh
+++ b/test/command-parsing.sh
@@ -9,6 +9,21 @@ if [ "$help_output" != "$invalid_option_output" ]; then
 	fail=$((fail+1))
 fi
 
+# --allow-missing-auth takes a required argument. When recognized, parsing
+# continues and --version runs (printing the version banner); an unrecognized
+# option would instead fall through to the help text.
+version_output="$(../src/apk --allow-missing-auth=example.com --version 2>/dev/null)"
+if ! echo "$version_output" | grep -q "^apk-tools "; then
+	echo "FAIL: --allow-missing-auth=VALUE is not recognized"
+	fail=$((fail+1))
+fi
+
+# The argument is mandatory: the bare option must be a parse error.
+if ../src/apk --allow-missing-auth >/dev/null 2>&1; then
+	echo "FAIL: --allow-missing-auth without an argument should error"
+	fail=$((fail+1))
+fi
+
 if [ $fail -eq 0 ]; then
 	echo "OK: command parsing works"
 fi
diff --git a/test/url-host-match.c b/test/url-host-match.c
new file mode 100644
index 0000000..2b57e79
--- /dev/null
+++ b/test/url-host-match.c
@@ -0,0 +1,78 @@
+/* url-host-match.c - unit test for apk_url_host_matches()
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#include <stdio.h>
+
+/* Provided by libapk (src/print.c); declared here to avoid pulling in the
+ * full apk header chain for a standalone test binary. */
+extern int apk_url_host_matches(const char *url, const char *list);
+
+static int failed = 0;
+
+static void check(const char *url, const char *list, int expect)
+{
+	int got = apk_url_host_matches(url, list);
+	if (got != expect) {
+		printf("FAIL: apk_url_host_matches(\"%s\", %s%s%s) = %d, expected %d\n",
+			url,
+			list ? "\"" : "", list ? list : "NULL", list ? "\"" : "",
+			got, expect);
+		failed++;
+	}
+}
+
+int main(void)
+{
+	/* Hosts use the RFC 2606 reserved example.* domains. */
+
+	/* exact host+path matches; a bare host does not match a URL with a path */
+	check("https://pkgs.example.com/repo", "pkgs.example.com/repo", 1);
+	check("https://pkgs.example.com/repo", "pkgs.example.com", 0);
+
+	/* prefix glob: any path on the host */
+	check("https://pkgs.example.com/repo", "pkgs.example.com/*", 1);
+
+	/* leading glob matches subdomains too */
+	check("https://mirror.example.com/repo", "*.example.com/*", 1);
+	check("https://submirror.example.com/repo", "*mirror.example.com/*", 1);
+
+	/* glob in the middle: ignore a changing path segment (e.g. a token) */
+	check("https://mirror.example.com/abc123/repo",
+	      "mirror.example.com/*/repo", 1);
+
+	/* per-path scoping */
+	check("https://pkgs.example.com/myorg", "pkgs.example.com/myorg*", 1);
+	check("https://pkgs.example.com/other", "pkgs.example.com/myorg*", 0);
+
+	/* a lone "*" matches any URL */
+	check("https://anything.example.org/x", "*", 1);
+
+	/* non-matches: unrelated host, and anchored patterns are not fooled by
+	 * lookalike hosts (no accidental suffix match) */
+	check("https://example.net/x", "pkgs.example.com/*", 0);
+	check("https://evil-pkgs.example.com/x", "pkgs.example.com/*", 0);
+	check("https://evilexample.com/x", "*.example.com/*", 0);
+
+	/* empty or absent list never matches */
+	check("https://pkgs.example.com/x", "", 0);
+	check("https://pkgs.example.com/x", NULL, 0);
+
+	/* comma/space separated list */
+	check("https://pkgs.example.com/repo", "example.net/*, pkgs.example.com/*", 1);
+	check("https://pkgs.example.com/repo", "example.net/* example.org/*", 0);
+
+	/* userinfo and port are stripped before matching */
+	check("https://user:pw@pkgs.example.com:443/repo", "pkgs.example.com/repo", 1);
+
+	/* non-URL (e.g. local cache path) has no host, matches nothing */
+	check("/var/cache/apk", "*", 0);
+
+	if (failed) {
+		printf("FAIL: %d host-match case(s) failed\n", failed);
+		return 1;
+	}
+	printf("OK: all host-match cases passed\n");
+	return 0;
+}
