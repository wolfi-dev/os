`base/logging.h` is only transitively included if VAAPI is enabled.  As we
build with `use_vaapi=false` on aarch64, we see a build failure without this
patch.

--- a/media/gpu/sandbox/hardware_video_decoding_sandbox_hook_linux.cc
+++ b/media/gpu/sandbox/hardware_video_decoding_sandbox_hook_linux.cc
@@ -7,6 +7,7 @@
 #include <dlfcn.h>
 #include <sys/stat.h>

+#include "base/logging.h"
 #include "base/process/process_metrics.h"
 #include "base/strings/stringprintf.h"
 #include "build/build_config.h"
