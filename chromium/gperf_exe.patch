Upstream have moved to using an in-tree (ish; CIPD actually stores it
elsewhere) gperf, so we need to point back at our system binary.

diff --git a/third_party/blink/renderer/build/scripts/scripts.gni b/third_party/blink/renderer/build/scripts/scripts.gni
index 6bba8f2..cf5c2b1 100644
--- a/third_party/blink/renderer/build/scripts/scripts.gni
+++ b/third_party/blink/renderer/build/scripts/scripts.gni
@@ -109,7 +109,7 @@ if (host_os == "win") {
   }
   gperf_exe = _mac_bin_path + "gperf"
 } else {
-  gperf_exe = "//third_party/gperf/cipd/bin/gperf"
+  gperf_exe = "/usr/bin/gperf"
 }
 
