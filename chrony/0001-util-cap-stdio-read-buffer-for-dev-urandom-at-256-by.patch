From 8e82fe6452b2bdaada9ec634826464b6e61acd0b Mon Sep 17 00:00:00 2001
From: Markus Boehme <markus.boehme@chainguard.dev>
Date: Thu, 25 Jun 2026 14:41:27 +0200
Subject: [PATCH] util: cap stdio read buffer for /dev/urandom at 256 bytes

UTI_GetRandomBytesUrandom uses libc stdio streams to get randomness from
/dev/urandom. stdio streams commonly use buffers to reduce calls to the
kernel and make IO more efficient without the caller having to worry
about small reads and writes. On systems where reads from /dev/urandom
are slow, however, it is more efficient to use smaller buffers and read
less randomness that might just go unused.

As one example, when chronyc is talking to chronyd via a Unix socket, it
creates a directory named with 16 random characters. More than 16 bytes
of randomness are needed to generate a name due to rejection sampling,
but the amount of random bytes consumed stays far behind the block size
that e.g. glibc is reading into its buffer: Being an in-memory file
system, the block size equals the system page size. That is 4096 bytes
of randomness of which most is thrown away.

Cap the buffer used by stdio streams for reading /dev/urandom to 256
bytes. This mirrors the buffer size already used for getrandom calls.

Signed-off-by: Markus Boehme <markus.boehme@chainguard.dev>
---
 util.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/util.c b/util.c
index 404e5b7..32abe6c 100644
--- a/util.c
+++ b/util.c
@@ -1522,8 +1522,16 @@ static FILE *urandom_file = NULL;
 void
 UTI_GetRandomBytesUrandom(void *buf, unsigned int len)
 {
-  if (!urandom_file)
+  static char urandom_buf[256];
+
+  /* Cap the stdio buffer so small reads don't pull a st_blksize (e.g. 4 KiB)
+   * of randomness from the kernel at once on systems where this is slow. */
+  if (!urandom_file) {
     urandom_file = UTI_OpenFile(NULL, DEV_URANDOM, NULL, 'R', 0);
+    if (setvbuf(urandom_file, urandom_buf, _IOFBF, sizeof (urandom_buf)))
+      LOG(LOGS_DEBUG, "Could not cap urandom buffer: %s", strerror(errno));
+  }
+
   if (fread(buf, 1, len, urandom_file) != len)
     LOG_FATAL("Can't read from %s", DEV_URANDOM);
 }
