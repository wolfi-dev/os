Description: Use system OpenSSL
 .
 This patch modifies ClickHouse to use system OpenSSL libraries instead of 
 bundled ones, to prevent unwanted aarch64 optimizations. It includes:
 - Using system OpenSSL via find_package instead of contrib
Author: Chris Herborth <chris.herborth@chainguard.dev> with bits from Michael Paul <michael.paul@chainguard.dev>
Forwarded: not-needed


diff --git a/CMakeLists.txt b/CMakeLists.txt
index e87d735f..5d02e453 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -472,6 +472,7 @@ enable_testing() # Enable for tests without binary
 
 set(ENABLE_OPENSSL_DYNAMIC_DEFAULT OFF)
 option(ENABLE_OPENSSL_DYNAMIC "This option removes SSL from ClickHouse and will link to the OpenSSL version supplied by OS." ${ENABLE_OPENSSL_DYNAMIC_DEFAULT})
+find_package(OpenSSL COMPONENTS Crypto SSL)
 
 # when installing to /usr - place configs to /etc but for /usr/local place to /usr/local/etc
 if (CMAKE_INSTALL_PREFIX STREQUAL "/usr")
@@ -482,6 +483,26 @@ endif ()
 
 message (STATUS "Building for: ${CMAKE_SYSTEM} ${CMAKE_SYSTEM_PROCESSOR} ${CMAKE_LIBRARY_ARCHITECTURE}")
 
+# Use system OpenSSL for FIPS compliance
+if(ENABLE_OPENSSL_DYNAMIC OR ENABLE_SSL)
+    find_package(OpenSSL REQUIRED)
+    if(OpenSSL_Found)
+        message(STATUS "Using system OpenSSL: ${OPENSSL_VERSION}")
+        if(NOT TARGET OpenSSL::Crypto)
+            add_library(OpenSSL::Crypto INTERFACE IMPORTED)
+            set_target_properties(OpenSSL::Crypto PROPERTIES
+                INTERFACE_INCLUDE_DIRECTORIES "${OPENSSL_INCLUDE_DIR}"
+                INTERFACE_LINK_LIBRARIES "${OPENSSL_CRYPTO_LIBRARY}")
+        endif()
+        if(NOT TARGET OpenSSL::SSL)
+            add_library(OpenSSL::SSL INTERFACE IMPORTED)
+            set_target_properties(OpenSSL::SSL PROPERTIES
+                INTERFACE_INCLUDE_DIRECTORIES "${OPENSSL_INCLUDE_DIR}"
+                INTERFACE_LINK_LIBRARIES "${OPENSSL_SSL_LIBRARY}")
+        endif()
+    endif()
+endif()
+
 # With cross-compiling, all targets are built for the target platform which usually different from the host
 # platform. This is problematic if a build artifact X (e.g. a file or an executable) is generated by running
 # another executable Y previously produced in the build. This is solved by compiling and running Y for/on
diff --git a/contrib/CMakeLists.txt b/contrib/CMakeLists.txt
index 2d01edbb..13f64642 100644
--- a/contrib/CMakeLists.txt
+++ b/contrib/CMakeLists.txt
@@ -43,8 +43,7 @@ endfunction()
 disable_heavy_build_check_if_needed()
 disable_dummy_launchers_if_needed()
 
-# We need to add OpenSSL first so that all our projects use our own version instead of the system one.
-add_contrib (openssl-cmake openssl)  # Needed for delta-lake
+# Using system OpenSSL for FIPS compliance
 add_contrib (abseil-cpp-cmake abseil-cpp)
 add_contrib (zlib-ng-cmake zlib-ng)
 add_contrib (google-protobuf-cmake google-protobuf)
diff --git a/contrib/delta-kernel-rs-cmake/CMakeLists.txt b/contrib/delta-kernel-rs-cmake/CMakeLists.txt
index 7fc6082e..bc2bea2a 100644
--- a/contrib/delta-kernel-rs-cmake/CMakeLists.txt
+++ b/contrib/delta-kernel-rs-cmake/CMakeLists.txt
@@ -35,8 +35,8 @@ corrosion_set_env_vars(delta_kernel_ffi
         "CARGO_TARGET_DIR=${DELTA_KERNEL_TARGET_PATH}"
         "OPENSSL_LIBS=ssl:crypto"
         "OPENSSL_STATIC=1"
-        "OPENSSL_LIB_DIR=${CMAKE_BINARY_DIR}/contrib/openssl-cmake/"
-        "OPENSSL_INCLUDE_DIR=${CMAKE_BINARY_DIR}/contrib/openssl-cmake/common/")
+        "OPENSSL_LIB_DIR=/usr/lib"
+        "OPENSSL_INCLUDE_DIR=/usr/include")
 
 target_include_directories(delta_kernel_ffi INTERFACE "${DELTA_KERNEL_TARGET_PATH}/")
 target_link_libraries(delta_kernel_ffi INTERFACE OpenSSL::Crypto OpenSSL::SSL)
diff --git a/programs/keeper/keeper_main.cpp b/programs/keeper/keeper_main.cpp
index 8cadad76..212eb219 100644
--- a/programs/keeper/keeper_main.cpp
+++ b/programs/keeper/keeper_main.cpp
@@ -1,5 +1,6 @@
 #include <unistd.h>
 #include <fcntl.h>
+#include <dlfcn.h>
 
 #include <new>
 #include <iostream>
@@ -96,12 +97,18 @@ static bool isClickhouseApp(std::string_view app_suffix, std::vector<char *> & a
 /// We absolutely discourage the ancient technique of loading
 /// 3rd-party uncontrolled dangerous libraries into the process address space,
 /// because it is insane.
+/// Exception: OpenSSL legacy provider module.
 
 #if !defined(USE_MUSL)
 extern "C"
 {
-    void * dlopen(const char *, int)
+    void * dlopen(const char * filename, int flags)
     {
+        if (filename && strstr(filename, "legacy.so") && strstr(filename, "/ossl-modules/"))
+        {
+            void * (*real_dlopen)(const char *, int) = reinterpret_cast<void *(*)(const char *, int)>(dlsym(RTLD_NEXT, "dlopen"));
+            return real_dlopen ? real_dlopen(filename, flags) : nullptr;
+        }
         return nullptr;
     }
 
@@ -115,9 +122,10 @@ extern "C"
         return 0;
     }
 
-    const char * dlerror()
+    char * dlerror()
     {
-        return "ClickHouse does not allow dynamic library loading";
+        char * (*real_dlerror)() = reinterpret_cast<char *(*)()>(dlsym(RTLD_NEXT, "dlerror"));
+        return real_dlerror ? real_dlerror() : const_cast<char *>("ClickHouse does not allow dynamic library loading");
     }
 }
 #endif
