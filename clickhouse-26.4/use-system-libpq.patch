Description: Use system libpq
 .
 This patch modifies ClickHouse to use system libpq libraries instead of 
 bundled ones, to prevent unwanted aarch64 optimizations.
Author: Chris Herborth <chris.herborth@chainguard.dev>
Forwarded: not-needed

diff --git a/contrib/CMakeLists.txt b/contrib/CMakeLists.txt
index 95143606..b3fbdef3 100644
--- a/contrib/CMakeLists.txt
+++ b/contrib/CMakeLists.txt
@@ -154,10 +154,10 @@ add_contrib (hive-metastore-cmake hive-metastore) # requires: thrift, avro, arro
 add_contrib (cppkafka-cmake cppkafka)
 
 option(ENABLE_LIBPQXX "Enable PostgreSQL" ${ENABLE_LIBRARIES})
-if (ENABLE_LIBPQXX)
-    add_contrib (postgres-cmake postgres)
-    add_contrib (libpqxx-cmake libpqxx)
-endif()
+# if (ENABLE_LIBPQXX)
+#     add_contrib (postgres-cmake postgres)
+#     add_contrib (libpqxx-cmake libpqxx)
+# endif()
 
 add_contrib (rocksdb-cmake rocksdb) # requires: jemalloc, snappy, zlib, lz4, zstd, liburing
 add_contrib (nuraft-cmake NuRaft)
