+            "SZ_USE_NEON_AES=0"
+            "SZ_USE_NEON_SHA=0"
+            "SZ_USE_SVE=0"
+            "SZ_USE_SVE2=0"
+            "SZ_USE_SVE2_AES=0"
     )
 endif ()
