From: Azimjon Ulmasov <azimjon.ulmasov@chainguard.dev>
Date: Thu, 26 Feb 2026 00:00:00 +0000
Subject: [PATCH] The TypeScript mangler causes V8 heap exhaustion during build:vscode. Disable it to unblock the build

--- a/lib/vscode/build/lib/compilation.ts
+++ b/lib/vscode/build/lib/compilation.ts
@@ -133,2 +133,2 @@
 		let mangleStream = es.through();
-		if (build && !options.disableMangle) {
+		if (false) {
 			let ts2tsMangler: Mangler | undefined = new Mangler(compile.projectPath, (...data) => fancyLog(ansiColors.blue('[mangler]'), ...data), { mangleExports: true, manglePrivateFields: true });

