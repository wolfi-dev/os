From: Chainguard <support@chainguard.dev>
Subject: Make dnsdist-lua.cc build with boost >= 1.91

The `boost::optional<T>::optional(U&&)` constructor became `explicit`
in boost 1.91, so copy-list-initialization (`T t = {expr}`) no longer
compiles. Switching to direct-list-initialization (`T t{expr}`) is
allowed with an explicit constructor.

Upstream fixed this on `rel/dnsdist-2.0.x` after the 2.0.5 tag via
https://github.com/PowerDNS/pdns/pull/17256 (commit 6d6a3638c, fixes
https://github.com/PowerDNS/pdns/issues/17245), but that commit
landed on top of a prior `boost::optional` -> `std::optional`
migration that is not in 2.0.5, so the upstream diff does not apply
cleanly. This patch backports the equivalent brace-init change
suggested by the dnsdist maintainer (omoerbeek) in
https://github.com/PowerDNS/pdns/issues/17245#issuecomment-4320152868,
keeping the existing `boost::optional` type used at the 2.0.5 tag.

--- a/pdns/dnsdistdist/dnsdist-lua.cc
+++ b/pdns/dnsdistdist/dnsdist-lua.cc
@@ -3084,7 +3084,7 @@
         customName = std::optional(*optCustomName);
       }
       if (!customName) {
-        boost::optional<declare_metric_opts_t> vars = {boost::get<declare_metric_opts_t>(opts.get())};
+        boost::optional<declare_metric_opts_t> vars{boost::get<declare_metric_opts_t>(opts.get())};
         getOptionalValue<std::string>(vars, "customName", customName);
         getOptionalValue<bool>(vars, "withLabels", withLabels);
         checkAllParametersConsumed("declareMetric", vars);
@@ -3107,7 +3107,7 @@
       step = *custom_step;
     }
     else {
-      boost::optional<update_metric_opts_t> vars = {boost::get<update_metric_opts_t>(incOpts)};
+      boost::optional<update_metric_opts_t> vars{boost::get<update_metric_opts_t>(incOpts)};
       getOptionalValue<uint64_t>(vars, "step", step);
       getOptionalValue<LuaAssociativeTable<std::string>>(vars, "labels", labels);
       checkAllParametersConsumed("incMetric", vars);
@@ -3129,7 +3129,7 @@
       step = *custom_step;
     }
     else {
-      boost::optional<update_metric_opts_t> vars = {boost::get<update_metric_opts_t>(decOpts)};
+      boost::optional<update_metric_opts_t> vars{boost::get<update_metric_opts_t>(decOpts)};
       getOptionalValue<uint64_t>(vars, "step", step);
       getOptionalValue<LuaAssociativeTable<std::string>>(vars, "labels", labels);
       checkAllParametersConsumed("decMetric", vars);
