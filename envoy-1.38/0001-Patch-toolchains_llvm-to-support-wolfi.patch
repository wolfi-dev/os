From 221d15fae131f5e89e63e628be880b320b13b55c Mon Sep 17 00:00:00 2001
From: Dimitri John Ledkov <dimitri.ledkov@surgut.co.uk>
Date: Thu, 29 Jan 2026 08:06:22 +0100
Subject: [PATCH] Patch toolchains_llvm to support wolfi

---
 bazel/repositories.bzl |  6 +++++-
 bazel/toolchains.bzl   | 10 +---------
 2 files changed, 6 insertions(+), 10 deletions(-)

diff --git a/bazel/repositories.bzl b/bazel/repositories.bzl
index 7df0b1c741..6f547db7c9 100644
--- a/bazel/repositories.bzl
+++ b/bazel/repositories.bzl
@@ -953,7 +953,7 @@ def _toolchains_llvm():
     external_http_archive(
         name = "toolchains_llvm",
         patch_args = ["-p1"],
-        patches = ["@envoy_toolshed//:patches/toolchains_llvm.patch"],
+        patches = ["//:bazel/0001-Add-support-for-Chainguard-and-Wolfi-distributions.patch", "//:bazel/toolchains_llvm.patch"],
     )

 def _wasmtime():
diff --git a/bazel/toolchains.bzl b/bazel/toolchains.bzl
index aa296862d7..090235839d 100644
--- a/bazel/toolchains.bzl
+++ b/bazel/toolchains.bzl
@@ -14,16 +14,7 @@ def envoy_toolchains():
     )
     llvm_toolchain(
         name = "llvm_toolchain",
-        llvm_version = "18.1.8",
-        # These libs are only included for cross-compile targets
-        cxx_cross_lib = {
-            "linux-aarch64": "@libcxx_libs_aarch64",
-            "linux-x86_64": "@libcxx_libs_x86_64",
-        },
+        llvm_version = "19.1.7",
         cxx_standard = {"": "c++20"},
-        sysroot = {} if USE_LOCAL_SYSROOT else {
-            "linux-x86_64": "@sysroot_linux_amd64//:sysroot",
-            "linux-aarch64": "@sysroot_linux_arm64//:sysroot",
-        },
         toolchain_roots = {"": LLVM_PATH} if LLVM_PATH else {},
     )
