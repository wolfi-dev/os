From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: "Jan Alexander Steffens (heftig)" <heftig@archlinux.org>
Date: Fri, 13 Feb 2026 04:33:11 +0100
Subject: [PATCH] Fix sandbox to build with glibc 2.43

---
 .../chromium/sandbox/linux/system_headers/linux_seccomp.h        | 1 +
 1 file changed, 1 insertion(+)

Index: firefox-148.0/security/sandbox/chromium/sandbox/linux/system_headers/linux_seccomp.h
===================================================================
--- firefox-148.0.orig/security/sandbox/chromium/sandbox/linux/system_headers/linux_seccomp.h
+++ firefox-148.0/security/sandbox/chromium/sandbox/linux/system_headers/linux_seccomp.h
@@ -10,6 +10,8 @@
 
 #include "build/build_config.h"
 
+#include <signal.h>
+
 // The Seccomp2 kernel ABI is not part of older versions of glibc.
 // As we can't break compilation with these versions of the library,
 // we explicitly define all missing symbols.
@@ -214,8 +216,11 @@ struct seccomp_notif_addfd {
 #define SECCOMP_RET_INVALID 0x00010000U  // Illegal return value
 #endif
 
+// check glibc version < 2.43
+#if (__GLIBC__ < 2) || (__GLIBC__ == 2 && __GLIBC_MINOR__ < 43)
 #ifndef SYS_SECCOMP
 #define SYS_SECCOMP                   1
 #endif
+#endif
 
 #endif  // SANDBOX_LINUX_SYSTEM_HEADERS_LINUX_SECCOMP_H_
