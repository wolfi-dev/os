From 3563c9892c747219c976ad16edc35854c3187da9 Mon Sep 17 00:00:00 2001
From: Daniel Scharrer <~@ds.me>
Date: Tue, 31 Dec 2024 03:49:38 +0100
Subject: [PATCH] slice: Include boost/filesystem/directory.hpp for Boost >= 1.72

Boost 1.85 stopped transitively including <boost/filesystem/directory.hpp>
from <boost/filesystem/operations.hpp>, breaking innoextract 1.9 which
uses boost::filesystem::directory_iterator without an explicit include.

Combines upstream commits 3563c98 and 345b5cb from
https://github.com/dscharrer/innoextract master.

---
 src/stream/slice.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/stream/slice.cpp b/src/stream/slice.cpp
--- a/src/stream/slice.cpp
+++ b/src/stream/slice.cpp
@@ -29,6 +29,11 @@
 #include <boost/filesystem/operations.hpp>
 #include <boost/range/size.hpp>

+#include <boost/version.hpp>
+#if BOOST_VERSION >= 107200
+#include <boost/filesystem/directory.hpp>
+#endif
+
 #include "util/console.hpp"
 #include "util/load.hpp"
 #include "util/log.hpp"
