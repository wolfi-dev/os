Remove sysroot from llvm_toolchain to allow building against the Wolfi/Chainguard
system headers rather than a downloaded glibc sysroot.

Upstream now conditionalises the sysroot via USE_LOCAL_SYSROOT, but we remove
the argument entirely so the build always uses Wolfi system headers.
---
 bazel/toolchains.bzl | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/bazel/toolchains.bzl b/bazel/toolchains.bzl
index aa296862d7..090235839d 100644
--- a/bazel/toolchains.bzl
+++ b/bazel/toolchains.bzl
@@ -14,10 +14,6 @@ def envoy_toolchains():
     llvm_toolchain(
         name = "llvm_toolchain",
         llvm_version = "18.1.8",
         cxx_standard = {"": "c++20"},
-        sysroot = {} if USE_LOCAL_SYSROOT else {
-            "linux-x86_64": "@sysroot_linux_amd64//:sysroot",
-            "linux-aarch64": "@sysroot_linux_arm64//:sysroot",
-        },
         toolchain_roots = {"": LLVM_PATH} if LLVM_PATH else {},
     )
