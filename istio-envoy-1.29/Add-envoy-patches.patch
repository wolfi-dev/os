From bbae011803a0371cf9fe2532491ef1e980c06f60 Mon Sep 17 00:00:00 2001
From: Debasish Biswas <debasishbsws.dev@gmail.com>
Date: Fri, 27 Feb 2026 10:38:05 +0530
Subject: [PATCH] Patch istio WORKSPACE to add patches to the vendored envoy dependency.

0002-envoy-use-system-yq.patch uses system yq instead of the Bazel-downloaded
yq to avoid architecture-specific download failures on amd64.

Signed-off-by: Debasish Biswas <debasishbsws.dev@gmail.com>
---
 WORKSPACE | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/WORKSPACE b/WORKSPACE
index cd7515d..4169a61 100644
--- a/WORKSPACE
+++ b/WORKSPACE
@@ -41,6 +41,10 @@ http_archive(
     strip_prefix = ENVOY_REPO + "-" + ENVOY_SHA,
     url = "https://github.com/" + ENVOY_ORG + "/" + ENVOY_REPO + "/archive/" + ENVOY_SHA + ".tar.gz",
+    patches = [
+        "//:0002-envoy-use-system-yq.patch",
+    ],
+    patch_args = ["-p1"],
 )
