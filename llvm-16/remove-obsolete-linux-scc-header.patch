From 3dc4fd6dd41100f051a63642f449b16324389c96 Mon Sep 17 00:00:00 2001
From: cqwrteur <uwgghhbcad@gmail.com>
Date: Fri, 25 Apr 2026 06:23:32 +0000
Subject: [PATCH] [compiler-rt][sanitizer] Remove linux/scc.h (#194116)

The Linux kernel has removed the obsolete <linux/scc.h> UAPI header
(the Z8530 SCC AX.25 driver), so it is no longer shipped by the
linux-headers package. Remove its use in sanitizer_common, along with
the two now-unbuildable struct size definitions that depend on it.
Fixes this build error:

../../compiler-rt/lib/sanitizer_common/sanitizer_platform_limits_posix.cpp:153:10: fatal error: 'linux/scc.h' file not found
  153 | #include <linux/scc.h>
      |          ^~~~~~~~~~~~~

Origin: backport, https://github.com/llvm/llvm-project/commit/3dc4fd6dd41100f051a63642f449b16324389c96
Bug: https://github.com/llvm/llvm-project/pull/194110

---
 .../lib/sanitizer_common/sanitizer_platform_limits_posix.cpp  | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/compiler-rt/lib/sanitizer_common/sanitizer_platform_limits_posix.cpp b/compiler-rt/lib/sanitizer_common/sanitizer_platform_limits_posix.cpp
--- a/compiler-rt/lib/sanitizer_common/sanitizer_platform_limits_posix.cpp
+++ b/compiler-rt/lib/sanitizer_common/sanitizer_platform_limits_posix.cpp
@@ -150,7 +150,6 @@
 #include <linux/lp.h>
 #include <linux/mroute.h>
 #include <linux/mroute6.h>
-#include <linux/scc.h>
 #include <linux/serial.h>
 #include <sys/msg.h>
 #include <sys/ipc.h>
@@ -511,8 +510,6 @@
   unsigned struct_kbsentry_sz = sizeof(struct kbsentry);
   unsigned struct_mtconfiginfo_sz = sizeof(struct mtconfiginfo);
   unsigned struct_nr_parms_struct_sz = sizeof(struct nr_parms_struct);
-  unsigned struct_scc_modem_sz = sizeof(struct scc_modem);
-  unsigned struct_scc_stat_sz = sizeof(struct scc_stat);
   unsigned struct_serial_multiport_struct_sz
       = sizeof(struct serial_multiport_struct);
   unsigned struct_serial_struct_sz = sizeof(struct serial_struct);
--
2.47.2

