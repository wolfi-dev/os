Author: Chris Herborth <chris.herborth@chainguard.dev>
Forwarded: not-needed
Description: Fix CVEs in dependencies where we can, document the rest.
---
diff --git a/Gemfile.template b/Gemfile.template
index bcac1bc..029ecda 100644
--- a/Gemfile.template
+++ b/Gemfile.template
@@ -39,8 +39,28 @@ gem "webmock", "~> 3", :group => :development
 gem "simplecov", "~> 0.22.0", :group => :development
 gem "simplecov-json", require: false, :group => :development
 gem "murmurhash3", "= 0.1.6" # Pins until version 0.1.7-java is released
-gem "date", "= 3.3.3"
+gem "date", "~> 3.4.1"
 gem "thwait"
 gem "bigdecimal", "~> 3.1"
 gem "cgi", "~> 0.3.7" # Pins until a new jruby version with updated cgi is released (https://github.com/jruby/jruby/issues/8919)
 gem "jar-dependencies", "= 0.5.4" # Pin to avoid conflict with default
+
+# Attempt to address CVEs
+gem "erb", "~> 4.0.4.1"
+gem "net-imap", "~> 0.6.4"
+gem "nokogiri", "~> 1.19.3"
+gem "logstash-input-beats", "~> 7.0.9"
+gem "logstash-input-http", "~> 4.1.8"
+gem "logstash-input-tcp", "~> 7.0.9"
+
+# Remaining CVEs that require up-stream fixes:
+#
+# - jackson-core Medium GHSA-72hv-8253-57qq fixed in 2.18.6
+# - log4j-1.2-api Medium CVE-2026-34479 GHSA-h383-gmxw-35v2 fixed in 2.25.4
+#
+# Remaining CVEs that we're working to eliminate by getting Logstash to use
+# our JDK, JRuby, and JRuby-OpenSSL:
+#
+# - bcpkix-jdk18on Medium CVE-2026-5588 GHSA-wg6q-6289-32hp fixed in 1.84
+# - bcprov-jdk18on Medium CVE-2026-0636 GHSA-c3fc-8qff-9hwx fixed in 1.84,
+#                  High CVE-2026-5598 GHSA-p93r-85wp-75v3 fixed in 1.84
diff --git a/logstash-core/build.gradle b/logstash-core/build.gradle
index fb0ad2b..3fc81a3 100644
--- a/logstash-core/build.gradle
+++ b/logstash-core/build.gradle
@@ -247,6 +247,7 @@ dependencies {
     }
     implementation 'org.hdrhistogram:HdrHistogram:2.2.2'
     implementation 'org.javassist:javassist:3.30.2-GA'
+    implementation 'io.netty:netty-codec:4.1.133.Final'
     testImplementation "org.apache.logging.log4j:log4j-core-test:${log4jVersion}"
     testImplementation 'org.hamcrest:hamcrest:2.2'
     testImplementation 'org.hamcrest:hamcrest-library:2.2'
diff --git a/versions.yml b/versions.yml
index 3cece14..c36e1e1 100644
--- a/versions.yml
+++ b/versions.yml
@@ -28,5 +28,5 @@ jruby:
 #       bundler evaluates the gemspec via bin/logstash
 # Ensure Jackson version here is kept in sync with version used by jrjackson gem
 jrjackson: 0.4.21
-jackson: 2.16.2
-jackson-databind: 2.16.2
+jackson: 2.18.6
+jackson-databind: 2.18.6
