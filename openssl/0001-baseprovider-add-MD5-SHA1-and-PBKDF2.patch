From 2a9bb6aff7c546ebb3a916f427947dceea411c1d Mon Sep 17 00:00:00 2001
From: Dimitri John Ledkov <dimitri.ledkov@surgut.co.uk>
Date: Fri, 15 Aug 2025 19:43:56 +0100
Subject: [PATCH] baseprovider: add MD5, SHA1 and PBKDF2

Open up access to MD5, SHA1 and PBKDF2 from the base provider. This
allows access to these algorithms for non-security purposes from
higher level languages such as dotnet, python, ruby and others.

Crutially, this does not allow fips provider to use them for
cryptographically secure purposes such as calculating HMAC, DRBG,
PRNG, Signatures, KDF, etc.

PBKDF2 is for non-approved passwords, to enable rotating them to
approved ones, until next revalidation of the 3.4 provider.
---
 crypto/evp/p5_crpt2.c  |  8 +++++++-
 providers/baseprov.c   | 22 ++++++++++++++++++++++
 test/fips-and-base.cnf |  4 ++--
 3 files changed, 31 insertions(+), 3 deletions(-)

diff --git a/crypto/evp/p5_crpt2.c b/crypto/evp/p5_crpt2.c
index c944496339..976126f166 100644
--- a/crypto/evp/p5_crpt2.c
+++ b/crypto/evp/p5_crpt2.c
@@ -86,8 +86,14 @@ int PKCS5_PBKDF2_HMAC(const char *pass, int passlen, const unsigned char *salt,
     int saltlen, int iter, const EVP_MD *digest, int keylen,
     unsigned char *out)
 {
+    /*
+     * this legacy function already passes pkcs5:0 to allow
+     * non-approved passwords for rotation, pass "-fips" property
+     * query string whilst pkcs5:0 support is being resolved in the
+     * provider resubmission.
+     */
     return ossl_pkcs5_pbkdf2_hmac_ex(pass, passlen, salt, saltlen, iter, digest,
-        keylen, out, NULL, NULL);
+        keylen, out, NULL, "?fips=no");
 }
 
 int PKCS5_PBKDF2_HMAC_SHA1(const char *pass, int passlen,
diff --git a/providers/baseprov.c b/providers/baseprov.c
index 16d2f91bb1..24467176c0 100644
--- a/providers/baseprov.c
+++ b/providers/baseprov.c
@@ -68,6 +68,19 @@ static int base_get_params(void *provctx, OSSL_PARAM params[])
     return 1;
 }
 
+/*
+ * open up access to MD5 and SHA1 for digest/crc non-security
+ * purposes, does not allow to be used in HMAC/DRBG/PRNG/KEM/Signature
+ * by the fips provider, this allows us to completely remove SHA1 from
+ * the fips provider.
+ */
+static const OSSL_ALGORITHM base_digests[] = {
+    { PROV_NAMES_SHA1, "provider=base", ossl_sha1_functions },
+    { PROV_NAMES_MD5, "provider=base", ossl_md5_functions },
+    { PROV_NAMES_MD5_SHA1, "provider=base", ossl_md5_sha1_functions },
+    { NULL, NULL, NULL }
+};
+
 static const OSSL_ALGORITHM base_encoder[] = {
 #define ENCODER_PROVIDER "base"
 #include "encoders.inc"
@@ -99,6 +112,11 @@ static const OSSL_ALGORITHM base_rands[] = {
     { NULL, NULL, NULL }
 };
 
+static const OSSL_ALGORITHM base_kdfs[] = {
+    { PROV_NAMES_PBKDF2, "provider=base", ossl_kdf_pbkdf2_functions },
+    { NULL, NULL, NULL }
+};
+
 static const OSSL_ALGORITHM *base_query(void *provctx, int operation_id,
     int *no_cache)
 {
@@ -108,10 +126,14 @@ static const OSSL_ALGORITHM *base_query(void *provctx, int operation_id,
         return base_encoder;
     case OSSL_OP_DECODER:
         return base_decoder;
+    case OSSL_OP_DIGEST:
+        return base_digests;
     case OSSL_OP_STORE:
         return base_store;
     case OSSL_OP_RAND:
         return base_rands;
+    case OSSL_OP_KDF:
+        return base_kdfs;
     }
     return NULL;
 }
diff --git a/test/fips-and-base.cnf b/test/fips-and-base.cnf
index f233f83062..9fe4a828e4 100644
--- a/test/fips-and-base.cnf
+++ b/test/fips-and-base.cnf
@@ -9,10 +9,10 @@ config_diagnostics = 1
 providers = provider_sect
 # You MUST uncomment the following line to operate in a FIPS approved manner,
 # It is commented out here purely for testing purposes.
-#alg_section = evp_properties
+alg_section = evp_properties
 
 [evp_properties]
-default_properties = "fips=yes"
+default_properties = "?fips=yes"
 
 [provider_sect]
 fips = fips_sect
-- 
2.51.0

