Author: Sergio Durigan Junior <sergiodj@chainguard.dev>
Description: Fix FTBFS with Python < 3.12
 .
 Upstream fixed a potential deadlock when using GIL at:
 .
 https://github.com/metaopt/optree/commit/2762fea3f98efbbf5274116f6601e4a0c01f171d
 .
 This introduced some usages of py::gil_scoped_{release,acquire}_simple, which
 don't exist on Python < 3.12.  We have to selectively use the right types
 depending on the Python version we're compiling with.
 .
 It doesn't make sense to upstream this patch as they're targeting Python 3.14
 now.

diff --git a/include/optree/pytypes.h b/include/optree/pytypes.h
index 2dfea5f..230ff34 100644
--- a/include/optree/pytypes.h
+++ b/include/optree/pytypes.h
@@ -27,6 +27,11 @@ limitations under the License.
 
 #if PY_VERSION_HEX < 0x030C00F0  // Python 3.12.0
 #    include <structmember.h>    // PyMemberDef
+#    define GIL_SCOPED_RELEASE_TYPE py::gil_scoped_release
+#    define GIL_SCOPED_ACQUIRE_TYPE py::gil_scoped_acquire
+#else
+#    define GIL_SCOPED_RELEASE_TYPE py::gil_scoped_release_simple
+#    define GIL_SCOPED_ACQUIRE_TYPE py::gil_scoped_acquire_simple
 #endif
 
 #include <pybind11/eval.h>  // pybind11::exec
@@ -262,7 +267,7 @@ inline bool IsNamedTupleClass(const py::handle &type) {
 
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_read_lock lock{mutex};
         const auto it = cache.find(type);
@@ -274,12 +279,12 @@ inline bool IsNamedTupleClass(const py::handle &type) {
     const bool result = EVALUATE_WITH_LOCK_HELD(IsNamedTupleClassImpl(type), type);
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_write_lock lock{mutex};
         if (cache.size() < MAX_TYPE_CACHE_SIZE) [[likely]] {
 #if !defined(Py_GIL_DISABLED)
-            const py::gil_scoped_acquire_simple gil_acquire{};
+            const GIL_SCOPED_ACQUIRE_TYPE gil_acquire{};
 #endif
             cache.emplace(type, result);
             (void)py::weakref(type, py::cpp_function([type](py::handle weakref) -> void {
@@ -373,7 +378,7 @@ inline bool IsStructSequenceClass(const py::handle &type) {
 
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_read_lock lock{mutex};
         const auto it = cache.find(type);
@@ -385,12 +390,12 @@ inline bool IsStructSequenceClass(const py::handle &type) {
     const bool result = EVALUATE_WITH_LOCK_HELD(IsStructSequenceClassImpl(type), type);
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_write_lock lock{mutex};
         if (cache.size() < MAX_TYPE_CACHE_SIZE) [[likely]] {
 #if !defined(Py_GIL_DISABLED)
-            const py::gil_scoped_acquire_simple gil_acquire{};
+            const GIL_SCOPED_ACQUIRE_TYPE gil_acquire{};
 #endif
             cache.emplace(type, result);
             (void)py::weakref(type, py::cpp_function([type](py::handle weakref) -> void {
@@ -465,13 +470,13 @@ inline py::tuple StructSequenceGetFields(const py::handle &object) {
 
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_read_lock lock{mutex};
         const auto it = cache.find(type);
         if (it != cache.end()) [[likely]] {
 #if !defined(Py_GIL_DISABLED)
-            const py::gil_scoped_acquire_simple gil_acquire{};
+            const GIL_SCOPED_ACQUIRE_TYPE gil_acquire{};
 #endif
             return py::reinterpret_borrow<py::tuple>(it->second);
         }
@@ -480,12 +485,12 @@ inline py::tuple StructSequenceGetFields(const py::handle &object) {
     const py::tuple fields = EVALUATE_WITH_LOCK_HELD(StructSequenceGetFieldsImpl(type), type);
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_release_simple gil_release{};
+        const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
         const scoped_write_lock lock{mutex};
         if (cache.size() < MAX_TYPE_CACHE_SIZE) [[likely]] {
 #if !defined(Py_GIL_DISABLED)
-            const py::gil_scoped_acquire_simple gil_acquire{};
+            const GIL_SCOPED_ACQUIRE_TYPE gil_acquire{};
 #endif
             cache.emplace(type, fields);
             fields.inc_ref();
diff --git a/src/treespec/traversal.cpp b/src/treespec/traversal.cpp
