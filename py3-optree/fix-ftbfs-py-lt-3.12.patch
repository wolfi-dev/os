--- a/src/treespec/traversal.cpp
+++ b/src/treespec/traversal.cpp
@@ -163,12 +163,12 @@ py::object PyTreeIter::NextImpl() {
 
 py::object PyTreeIter::Next() {
 #if !defined(Py_GIL_DISABLED)
-    const py::gil_scoped_release_simple gil_release{};
+    const GIL_SCOPED_RELEASE_TYPE gil_release{};
 #endif
     const scoped_lock lock{m_mutex};
     {
 #if !defined(Py_GIL_DISABLED)
-        const py::gil_scoped_acquire_simple gil_acquire{};
+        const GIL_SCOPED_ACQUIRE_TYPE gil_acquire{};
 #endif
         if (m_none_is_leaf) [[unlikely]] {
             return NextImpl<NONE_IS_LEAF>();
