--- a/libqpdf/CMakeLists.txt
+++ b/libqpdf/CMakeLists.txt
@@ -389,7 +389,10 @@ configure_file(
   "${CMAKE_CURRENT_BINARY_DIR}/qpdf/qpdf-config.h"
   NEWLINE_STYLE UNIX)

-if(NOT BUILD_STATIC_LIBS)
+# Also enable PIC for the object library when the caller explicitly requests it
+# via CMAKE_POSITION_INDEPENDENT_CODE, so that libqpdf.a can be linked into a
+# shared object.
+if(NOT BUILD_STATIC_LIBS OR CMAKE_POSITION_INDEPENDENT_CODE)
   set(OBJECT_LIB_IS_PIC ON)
 else()
   set(OBJECT_LIB_IS_PIC OFF)
@@ -526,11 +529,9 @@ if(BUILD_STATIC_LIBS)
   else()
     set(STATIC_LIB libqpdf)
   endif()
-  if(OBJECT_LIB_IS_PIC)
-    add_library(${STATIC_LIB} STATIC ${libqpdf_SOURCES})
-  else()
-    add_library(${STATIC_LIB} STATIC $<TARGET_OBJECTS:libqpdf_object>)
-  endif()
+  # Always use the pre-compiled object library so the static lib inherits the
+  # correct PIC setting (on or off) from the object library target.
+  add_library(${STATIC_LIB} STATIC $<TARGET_OBJECTS:libqpdf_object>)

   target_include_directories(${STATIC_LIB}
     SYSTEM PRIVATE ${dep_include_directories})
