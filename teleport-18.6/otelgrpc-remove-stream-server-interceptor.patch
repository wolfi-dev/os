otelgrpc.StreamServerInterceptor() was removed in otelgrpc v0.63.0 in favour of a
stats.Handler approach. Remediating GHSA-whqx-f9j3-ch6m requires cosign/v2 v2.6.2
which transitively requires otelgrpc >= v0.63.0. The original code carried a nolint
comment noting a data race in the stats.Handler replacement; migrating to stats.Handler
is left for a future update.

--- a/lib/auth/middleware.go
+++ b/lib/auth/middleware.go
@@ -37,7 +37,6 @@
 	"github.com/gravitational/trace"
 	grpcprom "github.com/grpc-ecosystem/go-grpc-middleware/providers/prometheus"
 	"github.com/prometheus/client_golang/prometheus"
-	"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc"
 	"golang.org/x/net/http2"
 	"google.golang.org/grpc"
 	"google.golang.org/grpc/credentials"
@@ -617,11 +616,7 @@
 
