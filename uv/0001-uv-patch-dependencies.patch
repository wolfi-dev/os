From 2a9d601dcaf8aa8f04b257468a3ada3b396a36d9 Mon Sep 17 00:00:00 2001
From: Dimitri John Ledkov <dimitri.ledkov@surgut.co.uk>
Date: Sat, 14 Feb 2026 03:08:31 +0000
Subject: [PATCH] uv-patch-dependencies

Patch transitive dependency
---
 Cargo.toml | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/Cargo.toml b/Cargo.toml
index 9c51388..eb43ae7 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -196,11 +196,12 @@ regex-automata = { version = "0.4.8", default-features = false, features = [
   "std",
   "syntax",
 ] }
-reqsign = { version = "0.18.1", features = [
+reqsign = { version = "0.19.1", features = [
   "aws",
   "google",
   "default-context",
 ], default-features = false }
+reqsign-google = { version = "2.0.3" }
 reqwest = { version = "0.12.22", default-features = false, features = [
   "json",
   "gzip",
@@ -448,3 +449,7 @@ inherits = "release"
 
 [workspace.metadata.cargo-shear]
 ignored = ["uv-audit"]
+
+[patch.crates-io]
+reqsign = { path = "../opendal-reqsign/reqsign/" }
+reqsign-google = { path = "../opendal-reqsign/services/google/" }
