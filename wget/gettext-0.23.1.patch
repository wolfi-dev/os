From 00ac946664599f44eb5d8c45a5abfcd8b0690a46 Mon Sep 17 00:00:00 2001
From: Colin Watson <colin.watson@chainguard.dev>
Date: Wed, 18 Mar 2026 09:48:36 +0000
Subject: [PATCH] Pin gettext macros to <0.24

wget currently uses a version of Gnulib that ships macros from gettext
0.23.  gettext 0.24 changed how the `Makefile.in.in` file in a PO
directory is generated, and including both macro versions in different
parts of the same project results in a `gnulib_po/Makefile.in.in` that
tries to use an undefined `top_builddir` variable.

This patch can be dropped once Gnulib upgrades to gettext >=0.24 and
wget upgrades to a corresponding Gnulib version.
---
 configure.ac | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/configure.ac b/configure.ac
index 996c70d8..1eed46f5 100644
--- a/configure.ac
+++ b/configure.ac
@@ -261,8 +261,7 @@ dnl
 dnl Gettext
 dnl
 AM_GNU_GETTEXT([external],[need-ngettext])
-AM_GNU_GETTEXT_VERSION([0.19.3])
-AM_GNU_GETTEXT_REQUIRE_VERSION([0.19.3])
+AM_GNU_GETTEXT_VERSION([0.23.1])
 
 AC_PROG_RANLIB
 
-- 
2.43.0

